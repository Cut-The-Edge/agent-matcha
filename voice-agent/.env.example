# LiveKit
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# OpenRouter (LLM) — OpenAI-compatible API
OPENROUTER_API_KEY=

# ElevenLabs (TTS)
ELEVEN_API_KEY=

# Deepgram (STT + TTS)
DEEPGRAM_API_KEY=

# Convex (for Python agent HTTP calls)
CONVEX_URL=https://your-deployment.convex.cloud

# Twilio (SIP trunk)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_SIP_TRUNK_SID=
TWILIO_PHONE_NUMBER=

# Outbound calling (run sip_config.py to create trunk and get the ID)
# LIVEKIT_OUTBOUND_TRUNK_ID=

# Live transfer phone numbers (E.164 format, e.g. +15551234567)
DANI_PHONE=
JANE_PHONE=

# Audio recording (optional — S3-compatible storage)
# If not set, audio recording is skipped (transcript still saved)
# RECORDING_S3_BUCKET=
# RECORDING_S3_REGION=us-east-1
# RECORDING_S3_ACCESS_KEY=
# RECORDING_S3_SECRET_KEY=
